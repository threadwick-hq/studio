{
  "name": "stitchgrid-studio",
  "version": "1.0.0",
  "description": "stitchgrid studio — a crochet project designer. Design granny-square stitch charts the way you crochet them.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host --port 8080",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "crochet",
    "granny-square",
    "chart",
    "svg",
    "pattern",
    "designer",
    "antd",
    "react",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "antd": "^5.22.0",
    "iconoir-react": "^7.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
